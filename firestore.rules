rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- User Data ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /workoutSessions/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /activityLogs/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /purchases/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    // --- Global Orders ---
    match /orders/{id} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn(); // Users create orders on purchase
      allow update: if isAdmin(); // Admins update order status
    }

    // --- Admin Roles ---
    match /roles_admin/{userId} {
      // Allow a user to read their own admin document to check status
      allow get, read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
    }

    // --- Global Catalogs ---
    match /shopProducts/{productId} {
      allow read: if true;
    }
  }
}
