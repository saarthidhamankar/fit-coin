rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Core Philosophy:
     * - Users own their data under the /users/{userId} path.
     * - Roles are read-only for users under /roles_admin/{userId}.
     * - Global catalogs like products and achievements are public read.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Data ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /workoutSessions/{id} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }

      match /activityLogs/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /purchases/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    // --- Admin Roles ---
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list, write: if false; // Only manageable via console
    }

    // --- Global Catalogs ---
    match /shopProducts/{productId} {
      allow read: if true;
    }

    match /achievements/{achievementId} {
      allow read: if true;
    }
  }
}