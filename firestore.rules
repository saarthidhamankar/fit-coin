rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FitCoin Security Rules
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. All sensitive data (workouts, 
     * purchases, activity ledgers) is nested under a specific user's document path. 
     * Global data like products and achievements are publicly readable but protected 
     * from unauthorized modification.
     * 
     * Data Structure:
     * - /users/{userId}: The root for all private user data.
     * - /users/{userId}/workouts: Private workout logs.
     * - /users/{userId}/purchases: Private purchase history.
     * - /users/{userId}/activityLogs: Private chronological ledger of events.
     * - /products: Global catalog of reward items.
     * - /achievements: Global catalog of unlockable badges.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: We rely on the {userId} in the path to verify 
     *    ownership, eliminating the need for expensive cross-document lookups.
     * 2. Denormalization for Authorization: Sub-documents (Workouts, Purchases, etc.) 
     *    contain a 'userId' field that is validated against the path parameter 
     *    to ensure relational integrity.
     * 3. Prototyping Flexibility: We do not enforce strict data types or schemas for 
     *    content fields, allowing for rapid front-end iteration.
     * 4. Admin Restrictions: Collections like /products and /achievements are 
     *    read-only for standard users.
     */

    // --- HELPER FUNCTIONS ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies the document exists and the user is the owner (used for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the primary UserProfile document.
     * @path /users/{userId}
     * @allow (get, create, update) if the authenticated user matches the userId.
     * @deny (list) preventing user enumeration; (delete) user accounts are preserved.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot be listed/enumerated
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // Account deletion is a restricted administrative action
    }

    /**
     * @description Rules for a user's workout history.
     * @path /users/{userId}/workouts/{workoutId}
     * @allow (get, list, create) if the user owns the parent path.
     * @deny (create) if the internal 'userId' doesn't match the path.
     * @principle Nested path ownership with relational integrity checks.
     */
    match /users/{userId}/workouts/{workoutId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for a user's purchase history.
     * @path /users/{userId}/purchases/{purchaseId}
     * @allow (get, list, create) if the user owns the parent path.
     * @deny (update) as purchase history is typically immutable.
     * @principle Nested path ownership for private transactional data.
     */
    match /users/{userId}/purchases/{purchaseId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if false; // Purchases are immutable financial records
      allow delete: if false; // Purchases should not be deleted for audit purposes
    }

    /**
     * @description Rules for the Activity Log (The Ledger).
     * @path /users/{userId}/activityLogs/{activityLogId}
     * @allow (get, list, create) if the user owns the parent path.
     * @deny (update, delete) to ensure the integrity of the activity history.
     * @principle Immutable ledger pattern for user events.
     */
    match /users/{userId}/activityLogs/{activityLogId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if false; // Activity logs are historical records and cannot be edited
      allow delete: if false; // Activity logs are historical records and cannot be removed
    }

    /**
     * @description Global Product catalog for the rewards shop.
     * @path /products/{productId}
     * @allow (get, list) for any authenticated or public user.
     * @deny (create, update, delete) for all standard users.
     * @principle Public Read with Admin-Only Writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add administrative role check once defined
    }

    /**
     * @description Global Achievements and badges.
     * @path /achievements/{achievementId}
     * @allow (get, list) for any authenticated or public user.
     * @deny (create, update, delete) for all standard users.
     * @principle Public Read with Admin-Only Writes.
     */
    match /achievements/{achievementId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add administrative role check once defined
    }
  }
}