
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user of the FitCoin application, storing their unique identifier, wallet address, and aggregated fitness statistics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "walletAddress": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bannerUrl": { "type": "string", "format": "uri" },
        "totalFitCoinsEarned": { "type": "number" },
        "totalFitCoinsSpent": { "type": "number" },
        "totalWorkouts": { "type": "number" },
        "currentDailyStreak": { "type": "number" },
        "longestDailyStreak": { "type": "number" },
        "lastWorkoutDate": { "type": "string", "format": "date-time" },
        "lastLoginDate": { "type": "string", "format": "date-time" },
        "unlockedAchievementIds": { "type": "array", "items": { "type": "string" } },
        "monthlyChallengeProgress": { "type": "number" }
      },
      "required": ["id", "walletAddress", "totalFitCoinsEarned"]
    },
    "Workout": {
      "title": "Workout",
      "description": "Records the details of a single workout session logged by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "fitCoinsEarnedTotal": { "type": "number" }
      },
      "required": ["id", "userId", "type", "durationMinutes", "date", "fitCoinsEarnedTotal"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Records a user's product purchase including shipping details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "fitCoinsSpent": { "type": "number" },
        "shippingDetails": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "pincode": { "type": "string" },
            "phone": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "productId", "purchaseDate", "fitCoinsSpent", "shippingDetails"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "A chronological record of user actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "activityType": { "type": "string", "enum": ["WORKOUT_EARN", "PURCHASE_SPEND", "LOGIN", "CHALLENGE_COMPLETE"] },
        "description": { "type": "string" },
        "fitCoinsChange": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "activityType", "timestamp"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": { "$ref": "#/backend/entities/Workout" },
      "description": "User workout history."
    },
    "/users/{userId}/purchases/{purchaseId}": {
      "schema": { "$ref": "#/backend/entities/Purchase" },
      "description": "User purchase history."
    },
    "/users/{userId}/activityLogs/{activityLogId}": {
      "schema": { "$ref": "#/backend/entities/ActivityLog" },
      "description": "User activity ledger."
    }
  }
}
