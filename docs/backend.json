{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the FitCoin platform.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "totalWorkoutsCompleted": { "type": "number" },
        "currentStreakDays": { "type": "number" },
        "totalFitEarned": { "type": "number" },
        "lastWorkoutDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "WorkoutSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WorkoutSession",
      "type": "object",
      "description": "A recorded workout session.",
      "properties": {
        "userId": { "type": "string" },
        "workoutType": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "totalTokensEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "workoutType", "durationMinutes"]
    },
    "ActivityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityLog",
      "type": "object",
      "description": "A history entry for user actions and earnings.",
      "properties": {
        "userId": { "type": "string" },
        "activityType": { "type": "string", "enum": ["WORKOUT_EARN", "PURCHASE_SPEND", "STREAK_BREAK", "IDENTITY_GENESIS"] },
        "description": { "type": "string" },
        "fitCoinsChange": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "activityType", "description", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/workoutSessions/{workoutSessionId}",
        "definition": {
          "entityName": "WorkoutSession",
          "schema": { "$ref": "#/backend/entities/WorkoutSession" },
          "description": "User workout logs."
        }
      },
      {
        "path": "/users/{userId}/activityLogs/{logId}",
        "definition": {
          "entityName": "ActivityLog",
          "schema": { "$ref": "#/backend/entities/ActivityLog" },
          "description": "User action and transaction history."
        }
      }
    ]
  }
}
