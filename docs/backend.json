{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the core profile data for a user.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "walletAddress": { "type": "string" },
        "currentStreakDays": { "type": "number" },
        "totalWorkoutsCompleted": { "type": "number" },
        "totalFitEarned": { "type": "number" },
        "lastWorkoutDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "WorkoutSession": {
      "title": "WorkoutSession",
      "type": "object",
      "description": "A record of a single workout session.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workoutType": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "totalTokensEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AdminRole": {
      "title": "AdminRole",
      "type": "object",
      "description": "System role definition for administrative access.",
      "properties": {
        "userId": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile root document."
    },
    "/users/{userId}/workoutSessions/{id}": {
      "schema": "WorkoutSession",
      "description": "Individual workout session logs."
    },
    "/roles_admin/{userId}": {
      "schema": "AdminRole",
      "description": "Admin privileges check."
    }
  }
}