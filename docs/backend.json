
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the core profile data for a user.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "walletAddress": { "type": "string" },
        "currentStreakDays": { "type": "number" },
        "totalWorkoutsCompleted": { "type": "number" },
        "totalFitEarned": { "type": "number" },
        "lastWorkoutDate": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" },
        "bannerUrl": { "type": "string" }
      },
      "required": ["id"]
    },
    "WorkoutSession": {
      "title": "WorkoutSession",
      "type": "object",
      "description": "A record of a single workout session.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workoutType": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "totalTokensEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" }
      }
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "type": "object",
      "description": "A log entry for user activity.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "activityType": { "type": "string" },
        "description": { "type": "string" },
        "fitCoinsChange": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "A global record of a shop redemption for admin tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "fitCoinsSpent": { "type": "number" },
        "shippingDetails": { "type": "object" },
        "status": { "type": "string", "enum": ["order_confirmed", "shipped", "delivered"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile root document."
    },
    "/users/{userId}/workoutSessions/{id}": {
      "schema": "WorkoutSession",
      "description": "Individual workout session logs."
    },
    "/users/{userId}/activityLogs/{id}": {
      "schema": "ActivityLog",
      "description": "Log of user actions and FIT earnings."
    },
    "/orders/{id}": {
      "schema": "Order",
      "description": "Global shop orders for admin fulfillment."
    }
  }
}
